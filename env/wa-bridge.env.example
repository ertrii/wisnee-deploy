# Entorno del wa-bridge (solo prod). Lo autogenera el orquestador.
PORT=4100
# Debe coincidir con WA_BRIDGE_SECRET en server.env.
INTERNAL_SECRET=__match server WA_BRIDGE_SECRET__
# Endpoint del server que recibe los mensajes entrantes. wa-bridge deriva los
# demás webhooks (ack/edit/revoke/reaction/state) reemplazando /message.
WEBHOOK_URL=http://server:4000/api/whatsapp/webhook/message
# AUTH_DATA_PATH ya viene seteado en la imagen (volumen persistente).
