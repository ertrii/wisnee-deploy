# Credenciales de Postgres (las autogenera el orquestador).
# DEBEN coincidir con DB_* en server.env.
POSTGRES_USER=wisnee
POSTGRES_PASSWORD=__autogenerado__
POSTGRES_DB=wisnee

# Zona del contenedor de Postgres (logs y now()/current_date). Debe coincidir
# con TZ en server.env. La fija el `init`.
TZ=America/Lima
