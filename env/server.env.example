# Entorno del backend (wisnet-server). Lo autogenera el orquestador.
# Los secrets (SECRET_KEY, INIT_TOKEN, FISCAL_ENCRYPTION_KEY, DB_PASSWORD y los
# *_SECRET de los bridges) se generan solos; nadie los escribe a mano.

SERVER_PORT=4000
# Detrás del reverse proxy (TLS terminado en nginx). HTTPS=true + trust proxy
# hace que la cookie de sesión salga `secure`. Imprescindible para loguear.
HTTPS=true
PUBLIC_BASE_URL=https://tu-dominio.com
CORS_ORIGIN=https://tu-dominio.com
BASE_PATH=

# Postgres (host = nombre del servicio en la red interna). DB_* DEBE coincidir
# con db.env (POSTGRES_*).
DB_HOST=db
DB_PORT=5432
DB_USERNAME=wisnee
DB_PASSWORD=__match db.env__
DB_NAME=wisnee

# Secrets autogenerados
SECRET_KEY=__autogenerado__
INIT_TOKEN=__autogenerado__
# 32 bytes en base64: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
FISCAL_ENCRYPTION_KEY=__autogenerado_base64_32B__

# Bridges (hostnames internos). El *_SECRET debe coincidir con INTERNAL_SECRET
# del bridge correspondiente. En Demo (core-only) estos servicios no existen:
# el server lo tolera (las features de Red/WhatsApp quedan inactivas).
WA_BRIDGE_URL=http://wa-bridge:4100
WA_BRIDGE_SECRET=__match wa-bridge INTERNAL_SECRET__
MK_BRIDGE_URL=http://mk-bridge:4200
MK_BRIDGE_SECRET=__match mk-bridge INTERNAL_SECRET__

# Correo saliente (opcional)
MAIL_HOST=
MAIL_USER=
MAIL_PASSWORD=
