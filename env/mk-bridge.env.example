# Entorno del mk-bridge (solo prod). Lo autogenera el orquestador.
PORT=4200
# Debe coincidir con MK_BRIDGE_SECRET en server.env.
INTERNAL_SECRET=__match server MK_BRIDGE_SECRET__
# En producción, túneles reales (no simulados).
DRY=false
WG_CONFIG_DIR=/etc/wireguard
WG_REVERSE_LISTEN_PORT=51820
# host:port público que cada Mikrotik usará como endpoint del peer WG reverso.
# Debe resolver desde internet (dominio o IP pública del VPS) + WG_REVERSE_LISTEN_PORT.
WG_REVERSE_PUBLIC_ENDPOINT=tu-dominio.com:51820
