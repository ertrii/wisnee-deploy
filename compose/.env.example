# Variables que interpola docker compose (NO son secrets de la app).
# El orquestador genera el .env real a partir de las respuestas del operador.

# Tag global de las imágenes a desplegar (latest, v1.2.3, o un sha). Pinéalo
# para poder hacer rollback. Es el default de TODOS los servicios.
TAG=latest

# Tags por servicio (opcionales). Si se definen, GANAN sobre TAG para ese
# servicio; si no, caen a TAG. Útil para subir solo el frontend sin recompilar
# el server: dejás TAG fijo y movés WEB_TAG al tag nuevo del web.
#   SERVER_TAG=   # wisnet-server (server, migrate, seed)
#   WEB_TAG=      # wisnet (frontend)
#   WA_TAG=       # wa-bridge
#   MK_TAG=       # mk-bridge

# Dominio público (sin esquema). Lo usa el reverse proxy y certbot.
DOMAIN=tu-dominio.com

# Entorno: "prod" o "demo". En demo el orquestador suma el overlay del seed.
APP_ENV=prod

# Puerto UDP público para el WireGuard reverso de mk-bridge (Mikrotiks CGNAT).
WG_REVERSE_LISTEN_PORT=51820
