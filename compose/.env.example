# Variables que interpola docker compose (NO son secrets de la app).
# El orquestador genera el .env real a partir de las respuestas del operador.

# Tag de las imágenes a desplegar (latest, v1.2.3, o un sha). Pinéalo para
# poder hacer rollback.
TAG=latest

# Dominio público (sin esquema). Lo usa el reverse proxy y certbot.
DOMAIN=tu-dominio.com

# Entorno: "prod" o "demo". En demo el orquestador suma el overlay del seed.
APP_ENV=prod

# Puerto UDP público para el WireGuard reverso de mk-bridge (Mikrotiks CGNAT).
WG_REVERSE_LISTEN_PORT=51820
