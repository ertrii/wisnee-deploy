# Variables que interpola docker compose (NO son secrets de la app).
# El orquestador genera el .env real a partir de las respuestas del operador.

# Tag global de las imágenes. Es el default de TODOS los servicios.
#   edge   = última main (rolling) — ideal para demo.
#   vX.Y.Z = release inmutable y COHERENTE (los 5 servicios a la misma versión)
#            — recomendado para prod; permite rollback exacto.
# Un release vX.Y.Z lo arma el workflow "Release" de este repo (retaggea los
# :edge). Ver README → "Versionado / Releases".
TAG=edge

# Tags por servicio (opcionales, ESCAPE HATCH). Si se definen ganan sobre TAG
# para ese servicio; si no, caen a TAG. Romper la coherencia front/back puede
# disparar la pantalla "old_version", así que usalos solo para hotfixes
# puntuales (p. ej. un fix de nginx/SEO que no toca el protocolo).
#   SERVER_TAG=   # wisnee-server (server, migrate, seed)
#   WEB_TAG=      # wisnee (frontend)
#   WA_TAG=       # wa-bridge
#   MK_TAG=       # mk-bridge

# Dominio público (sin esquema). Lo usa el reverse proxy y certbot.
DOMAIN=tu-dominio.com

# Entorno: "prod" o "demo". En demo el orquestador suma el overlay del seed.
APP_ENV=prod

# Puerto UDP público para el WireGuard reverso de mk-bridge (Mikrotiks CGNAT).
WG_REVERSE_LISTEN_PORT=51820
